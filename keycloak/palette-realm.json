{
  "realm": "palette",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard Palette user role",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "admin",
        "description": "Palette administrator role",
        "composite": false,
        "clientRole": false
      }
    ],
    "client": {
      "palette-bff": []
    }
  },
  "clients": [
    {
      "clientId": "palette-bff",
      "name": "Palette BFF",
      "description": "Palette BFF backend-for-frontend OIDC client",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "palette-secret",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:8080/login/oauth2/code/eidp",
        "http://localhost:8080/login/oauth2/code/*"
      ],
      "webOrigins": [
        "https://localhost:3000",
        "http://localhost:8080"
      ],
      "rootUrl": "http://localhost:8080",
      "baseUrl": "/",
      "adminUrl": "/",
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "consentRequired": false,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email",
        "basic"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "attributes": {
        "post.logout.redirect.uris": "https://localhost:3000##http://localhost:8080",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false"
      },
      "protocolMappers": [
        {
          "name": "audience resolve",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-resolve-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@palette.dev",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "admin",
        "default-roles-palette"
      ],
      "clientRoles": {
        "account": [
          "view-profile",
          "manage-account"
        ]
      }
    },
    {
      "username": "testuser",
      "enabled": true,
      "email": "testuser@palette.dev",
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "test123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "default-roles-palette"
      ],
      "clientRoles": {
        "account": [
          "view-profile",
          "manage-account"
        ]
      }
    }
  ],
  "defaultRole": {
    "name": "default-roles-palette",
    "description": "Default role for the Palette realm",
    "composite": true,
    "clientRole": false
  },
  "scopeMappings": [
    {
      "client": "palette-bff",
      "roles": [
        "user",
        "admin"
      ]
    }
  ],
  "browserSecurityHeaders": {
    "contentSecurityPolicyReportOnly": "",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains",
    "xContentTypeOptions": "nosniff",
    "xFrameOptions": "DENY",
    "xRobotsTag": "none",
    "xXSSProtection": "1; mode=block",
    "referrerPolicy": "no-referrer"
  },
  "smtpServer": {},
  "loginTheme": "keycloak",
  "accountTheme": "keycloak.v3",
  "adminTheme": "keycloak.v2",
  "emailTheme": "keycloak",
  "internationalizationEnabled": false,
  "supportedLocales": [],
  "browserFlow": "browser",
  "registrationFlow": "registration",
  "directGrantFlow": "direct grant",
  "resetCredentialsFlow": "reset credentials",
  "clientAuthenticationFlow": "clients"
}
